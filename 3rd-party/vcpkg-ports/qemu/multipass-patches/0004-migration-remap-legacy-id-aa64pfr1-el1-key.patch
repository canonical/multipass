From 45c077d7f774f4481e6dd41a417b2c9d2e2a04f5 Mon Sep 17 00:00:00 2001
From: Scott Harder <scott.harder@canonical.com>
Date: Wed, 15 Jul 2026 17:41:13 -0500
Subject: [PATCH] [migration] Remap legacy ID_AA64PFR1_EL1 key on cpu load

QEMU releases before commit 19ed42e8 ("hvf: arm: Fix encodings for
ID_AA64PFR1_EL1 and debug System registers") mapped ID_AA64PFR1_EL1 to the
wrong HVF sysreg encoding (op2=2 instead of op2=1). An instance suspended by
such a release records that register's value under the op2=2 key, so resuming
it under a fixed QEMU aborts in cpu_post_load() ("register in their list but
not ours").

Rewrite the legacy op2=2 key to the correct op2=1 key when loading CPU state.
The rewrite is order-preserving (no other cpreg sorts between the two keys)
and a no-op for natively-suspended instances, which never contain the legacy
key. This lets QEMU keep the correct upstream encoding for new instances while
still resuming ones suspended by the affected releases.

Drop once instances suspended by the affected releases are no longer supported.
---
 target/arm/machine.c | 25 +++++++++++++++++++++++++
 1 file changed, 25 insertions(+)

diff --git a/target/arm/machine.c b/target/arm/machine.c
index 978249fb71..de0e678f4c 100644
--- a/target/arm/machine.c
+++ b/target/arm/machine.c
@@ -5,6 +5,7 @@
 #include "system/tcg.h"
 #include "kvm_arm.h"
 #include "internals.h"
+#include "cpregs.h"
 #include "cpu-features.h"
 #include "migration/cpu.h"
 #include "target/arm/gtimer.h"
@@ -961,6 +962,30 @@ static int cpu_post_load(void *opaque, int version_id)
      * entries with the right slots in our own values array.
      */
 
+    /*
+     * Multipass suspend/resume compatibility across QEMU upgrades. QEMU
+     * releases before commit 19ed42e8 mapped ID_AA64PFR1_EL1 to the wrong HVF
+     * sysreg encoding (op2=2 instead of op2=1), so an instance suspended by
+     * such a release records that register's value under the op2=2 key. Rewrite
+     * the legacy key to the correct one on load so it matches this QEMU's
+     * register list. The rewrite is order-preserving (the two keys have no
+     * other list entry between them) and a no-op for native suspends, which
+     * never contain the legacy key. Drop once instances suspended by the
+     * affected releases are no longer supported.
+     */
+    {
+        const uint64_t legacy_pfr1 = cpreg_to_kvm_id(
+            ENCODE_AA64_CP_REG(CP_REG_ARM64_SYSREG_CP, 0, 4, 3, 0, 2));
+        const uint64_t correct_pfr1 = cpreg_to_kvm_id(
+            ENCODE_AA64_CP_REG(CP_REG_ARM64_SYSREG_CP, 0, 4, 3, 0, 1));
+        int mi;
+        for (mi = 0; mi < cpu->cpreg_vmstate_array_len; mi++) {
+            if (cpu->cpreg_vmstate_indexes[mi] == legacy_pfr1) {
+                cpu->cpreg_vmstate_indexes[mi] = correct_pfr1;
+            }
+        }
+    }
+
     for (i = 0, v = 0; i < cpu->cpreg_array_len
              && v < cpu->cpreg_vmstate_array_len; i++) {
         if (cpu->cpreg_vmstate_indexes[v] > cpu->cpreg_indexes[i]) {
-- 
