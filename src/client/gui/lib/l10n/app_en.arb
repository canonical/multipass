{
    "@@locale": "en",
    "beforeQuitTitle": "Stop running instances?",
    "@beforeQuitTitle": {
        "description": "Title of the dialog asking the user whether to stop running VMs on quit"
    },
    "beforeQuitMessage": "{count, plural, =1{There is 1 running instance. Do you want to stop it?} other{There are {count} running instances. Do you want to stop them?}}",
